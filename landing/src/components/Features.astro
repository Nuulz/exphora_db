---
// src/components/Features.astro
const features = [
  {
    title: "Multi-format support",
    description: "Open JSON, CSV, NDJSON, SQLite and XML. Automatic schema inference on any dataset.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="9" y2="21"/></svg>`
  },
  {
    title: "Powerful filters",
    description: "Filter by column, write expressions, search with highlight. Built for real data.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`
  },
  {
    title: "Export anywhere",
    description: "Export to CSV, JSON, Excel, Markdown or PDF with a single shortcut.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`
  },
  {
    title: "Keyboard first",
    description: "Full keyboard navigation. Every action has a shortcut. No mouse required.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2" ry="2"/><path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><path d="M18 8h.01"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/><path d="M7 16h10"/></svg>`
  },
  {
    title: "P2P sharing",
    description: "Share datasets directly person-to-person. Compressed, encrypted. No servers.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>`
  },
  {
    title: "Local-first",
    description: "Your data never leaves your machine. No accounts, no cloud, no tracking.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" x2="12" y1="22.08" y2="12"/></svg>`
  }
];
---
<section id="features" class="py-24 px-6 max-w-6xl mx-auto">
  <div class="text-center mb-16">
    <h2 class="text-[2rem] font-bold text-text-primary">Everything you need to work with data</h2>
  </div>

  <div class="features-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {features.map((feature) => (
      <div class="feature-card opacity-0 translate-y-[30px] bg-surface-elevated border border-border rounded-lg p-6 hover:border-brand/40 transition-colors duration-300">
        <div class="flex items-center justify-center w-12 h-12 bg-surface rounded-md mb-6 text-brand border border-border-strong shadow-sm">
          <Fragment set:html={feature.icon} />
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-3 tracking-tight">{feature.title}</h3>
        <p class="text-text-secondary leading-relaxed text-[15px]">{feature.description}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  const cards = document.querySelectorAll('.feature-card');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  if (!prefersReducedMotion && cards.length > 0) {
    inView('.features-grid', () => {
      // Convert to Array to ensure proper stagger index handling if needed,
      // though motion handles NodeLists well.
      animate(Array.from(cards), 
        { opacity: [0, 1], y: [30, 0] }, 
        { duration: 0.5, delay: (index) => index * 0.08, ease: 'easeOut' }
      );
    }, { margin: "-10% 0px", once: true });
  } else {
    cards.forEach(card => {
      if (card instanceof HTMLElement) {
        card.style.opacity = '1';
        card.style.transform = 'none';
      }
    });
  }
</script>
