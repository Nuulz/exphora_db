---
// src/components/Changelog.astro
const updates = [
  {
    version: "v0.8.4",
    date: "March 13, 2026",
    title: "Relational Operators & Dashboard Polish",
    description: "Closes the last technical debt of the expression parser and adds inline widget title editing.",
    changes: [
      { type: "Added", text: "Full relational operator support in calculated columns: >, <, >=, <=, ==, != with correct Pratt precedence. Works inside if() and countif()." },
      { type: "Added", text: "String comparison via == and != operators. Lexicographic ordering for >, <, >=, <=." },
      { type: "Added", text: "Inline editable widget titles in the dashboard: double-click any widget header to rename it. Enter confirms, Escape cancels. Persisted in the .exh view file." },
      { type: "Fixed", text: "countif() and if() conditions now use native relational syntax (countif(price > 100)) instead of arithmetic workarounds." },
      { type: "Fixed", text: "num() now returns 0.0 instead of Null when the value is not parseable as a number." }
    ]
  },
  {
    version: "v0.8.3",
    date: "March 13, 2026",
    title: "Advanced Expression Functions",
    description: "Extends the Pratt parser with aggregate and utility functions for calculated columns.",
    changes: [
      { type: "Added", text: "Aggregate functions in calculated columns: sum(col), avg(col), countif(condition). Operate exclusively over filtered rows — results update when filters change." },
      { type: "Added", text: "Conditional function: if(condition, value_if_true, value_if_false) with lazy evaluation — the false branch is never computed." },
      { type: "Added", text: "Utility functions: round(expr, decimals), num(value) for safe numeric casting." },
      { type: "Added", text: "41 unit tests covering all new parser functions." }
    ]
  },
  {
    version: "v0.8.2",
    date: "March 13, 2026",
    title: "Lightweight Dashboard per View",
    description: "Each saved view can now hold up to 3 chart widgets with drag & drop, zoom, pan, and fullscreen support.",
    changes: [
      { type: "Added", text: "Dashboard layout per view: up to 3 chart slots (histogram, bar, line) persisted inside the .exh file." },
      { type: "Added", text: "Add Chart wizard: choose chart type, X column, and optional Y column in 3 clicks." },
      { type: "Added", text: "Drag & drop between slots via @dnd-kit with swap logic. Reordering persists immediately to disk." },
      { type: "Added", text: "Zoom and pan inside any widget using mouse wheel and drag (react-zoom-pan-pinch). Disabled automatically during slot drag." },
      { type: "Added", text: "Brush selector on X axis for bar and line charts when there are more than 15 data points." },
      { type: "Added", text: "Per-widget fullscreen mode via React Portal. Close with Minimize button or Escape key." },
      { type: "Added", text: "Dashboard toggle button in TabBar (collapsed by default). State is session-only, not saved to .exh." }
    ]
  },
  {
    version: "v0.8.1",
    date: "March 13, 2026",
    title: "Unified Chart System",
    description: "Moves all chart data aggregation to Rust and introduces a reusable chart architecture.",
    changes: [
      { type: "Added", text: "Tauri command build_chart_data(records, filtered_indices, config): all aggregation logic now runs in Rust, not TypeScript." },
      { type: "Added", text: "ChartConfig interface in TypeScript: type, xColumn, yColumn, groupByColumn, aggregation, limit, id, options." },
      { type: "Added", text: "useChartData() custom hook: centralized async loading with 150ms debounce, isMounted cleanup, and loading/error states." },
      { type: "Added", text: "chartTheme.tsx: shared colors, tooltips and loading overlays across all chart components." },
      { type: "Added", text: "BarChart and LineChart components as thin wrappers over useChartData." },
      { type: "Improved", text: "FrequencyChart migrated to the new backend. Frequency calculation moved from TypeScript to Rust." }
    ]
  },
  {
    version: "v0.7.2",
    date: "March 11, 2026",
    title: "Views, Persistence & Notes Panel",
    description: "The biggest productivity update yet. Introducing Exphora Views, Smart Save, floating Markdown notes, and column annotations.",
    changes: [
      { type: "Added", text: "View system (.exh files): save and restore complete tab states including filters, column config, sorting, calculated columns, pinned columns, and chart states." },
      { type: "Added", text: "Smart Save: after saving a view once, the Save button writes directly to the same file. A secondary (...) button lets you save to a new location." },
      { type: "Added", text: "Floating Markdown notes panel per view: draggable and resizable, with Code, Preview, and Split modes. Persisted in .exh." },
      { type: "Added", text: "Column annotations: add short notes to any column from the header context menu. Dot indicator and tooltip on annotated columns." },
      { type: "Added", text: "Recent Views section in the Sidebar. RelinkModal for views whose dataset has been moved or renamed." },
      { type: "Added", text: "Native .exh file association on Windows: open saved views directly from Explorer." },
      { type: "Fixed", text: "Landing page blank screen caused by missing <!DOCTYPE html> declaration (Tailwind v4 regression)." },
      { type: "Fixed", text: "Deep search highlight overlaps and column-specific field:value filter logic regressions." }
    ]
  }
];
---

<section id="changelog" class="py-24 px-6 max-w-4xl mx-auto border-t border-border/40 mt-12">
  <div class="mb-16">
    <h2 class="text-[2rem] font-bold text-text-primary mb-2 tracking-tight">What's New</h2>
    <p class="text-text-secondary text-[15px]">Keep up with the latest features, fixes, and architectural improvements.</p>
  </div>

  <div class="changelog-list space-y-12">
    {updates.map((update) => (
      <div class="changelog-item opacity-0 translate-y-[20px] relative pl-8 md:pl-0">
        
        {/* Desktop Layout timeline line */}
        <div class="hidden md:block absolute left-[120px] top-2 bottom-[-48px] w-px bg-border/50 last:bottom-0 z-0"></div>
        <div class="hidden md:block absolute left-[116px] top-[14px] w-[9px] h-[9px] rounded-full bg-brand border-[2px] border-bg z-10"></div>

        <div class="flex flex-col md:flex-row gap-4 md:gap-12 relative z-10">
          
          <div class="md:w-[100px] shrink-0 pt-1">
            <span class="inline-block px-2 py-0.5 rounded textxs font-semibold bg-surface-elevated text-brand border border-border/60 mb-1">
              {update.version}
            </span>
            <div class="text-[13px] text-text-muted mt-1">{update.date}</div>
          </div>

          <div class="flex-1 bg-surface border border-border/60 rounded-xl p-6 hover:border-border transition-colors">
            <h3 class="text-lg font-bold text-text-primary tracking-tight mb-2">{update.title}</h3>
            <p class="text-text-secondary text-[14px] leading-relaxed mb-6">{update.description}</p>
            
            <ul class="space-y-3">
              {update.changes.map(change => (
                <li class="flex items-start gap-3 text-[14px] text-text-secondary">
                  <span class={`shrink-0 mt-0.5 inline-flex items-center justify-center px-1.5 py-[2px] rounded font-medium text-[10px] uppercase tracking-wider
                    ${change.type === 'Added' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 
                      change.type === 'Fixed' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 
                      'bg-blue-500/10 text-blue-400 border border-blue-500/20'}
                  `}>
                    {change.type}
                  </span>
                  <span class="leading-relaxed">{change.text}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    ))}
  </div>
  <div class="mt-12 text-center mt-8">
      <a href="https://github.com/Nuulz/Exphora_db/releases" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[14px] font-medium text-brand hover:text-brand-hover transition-colors">
        View complete commit history
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  const items = document.querySelectorAll('.changelog-item');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  if (!prefersReducedMotion && items.length > 0) {
    inView('.changelog-list', () => {
      animate(Array.from(items), 
        { opacity: [0, 1], y: [20, 0] }, 
        { duration: 0.5, delay: (index) => index * 0.1, ease: 'easeOut' }
      );
    }, { margin: "-10% 0px", once: true });
  } else {
    items.forEach(el => {
      if (el instanceof HTMLElement) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      }
    });
  }
</script>
